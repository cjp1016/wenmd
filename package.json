{
  "name": "wenmd",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "build:mac": "tauri build --config '{\"bundle\":{\"targets\":[\"app\",\"dmg\"]}}'",
    "build:mac:dmg": "tauri build --config '{\"bundle\":{\"targets\":[\"dmg\"]}}'",
    "build:mac:app": "tauri build --config '{\"bundle\":{\"targets\":[\"app\"]}}'",
    "build:win": "tauri build --config '{\"bundle\":{\"targets\":[\"nsis\",\"msi\"]}}'",
    "build:win:nsis": "tauri build --config '{\"bundle\":{\"targets\":[\"nsis\"]}}'",
    "build:win:msi": "tauri build --config '{\"bundle\":{\"targets\":[\"msi\"]}}'"
  },
  "dependencies": {
    "@milkdown/crepe": "^7.21.3",
    "@milkdown/kit": "^7.21.3",
    "@milkdown/plugin-prism": "^7.21.3",
    "@milkdown/vue": "^7.21.3",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-window-state": "^2.4.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10"
  }
}
